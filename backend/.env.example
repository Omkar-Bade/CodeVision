# ── Database ─────────────────────────────────────────────────────────────────
# Connection details for the MySQL database.
# Copy this file to .env and fill in your actual values.
# The .env file must NEVER be committed to version control.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=codevision_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.:\
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (short-lived, ~15–30 min recommended)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days (long-lived, ~7 days recommended)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production (Render), set this to your deployed frontend URL, e.g.:
#   ALLOWED_ORIGINS=https://codevision-frontend.onrender.com
# Leave unset (or empty) for local development — localhost URLs are used as fallback.
ALLOWED_ORIGINS=

# ── SSL / CA Certificate (Aiven and other managed MySQL hosts) ────────────────
# Aiven enforces SSL and requires a CA certificate for server verification.
# Copy the full PEM text from your Aiven console and paste it here (Render encrypts it).
# Leave blank for local development — SSL is skipped automatically when this is unset.
# Example (Render dashboard env var):
#   DB_SSL_CA_CONTENT=-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----
DB_SSL_CA_CONTENT=
