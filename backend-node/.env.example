# Copy this file to .env and fill in your values
# Never commit .env to version control

# MongoDB connection string
# Local dev:  mongodb://localhost:27017/codevision
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net/codevision
MONGO_URI=mongodb://localhost:27017/codevision

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port for the Node.js API server
PORT=5000

# URL of the Python FastAPI execution service
PYTHON_API_URL=http://localhost:8000
