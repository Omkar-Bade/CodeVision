# ── Backend API URL ───────────────────────────────────────────────────────────
# URL of the FastAPI backend. No trailing slash.
#
# LOCAL DEVELOPMENT — copy this file to .env and keep the default:
VITE_API_URL=http://localhost:8000
#
# PRODUCTION (Render Static Site) — set this env var in the Render dashboard:
#   VITE_API_URL=https://<your-backend-service>.onrender.com
# Vite bakes this value into the production bundle at build time.
